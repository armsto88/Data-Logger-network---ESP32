FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}

dimensions      [0 1 -1 0 0 0 0];
internalField   uniform (0.707107 0.707107 0);

boundaryField
{
    inlet
    {
        type fixedValue;
        value uniform (0.707107 0.707107 0);
    }
    outlet
    {
        type zeroGradient;
    }
    sides
    {
        type slip;
    }
    top
    {
        type slip;
    }
    bottom
    {
        type slip;
    }
    anemometer
    {
        type noSlip;
    }
}
