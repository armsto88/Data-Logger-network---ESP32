FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}

dimensions      [0 2 -2 0 0 0 0];
internalField   uniform 0.1;

boundaryField
{
    inlet
    {
        type fixedValue;
        value uniform 0.1;
    }
    outlet
    {
        type zeroGradient;
    }
    sides
    {
        type zeroGradient;
    }
    top
    {
        type zeroGradient;
    }
    bottom
    {
        type zeroGradient;
    }
    anemometer
    {
        type kqRWallFunction;
        value uniform 0;
    }
}
