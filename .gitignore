.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/
.vscode/settings.json
.vscode/tasks.json

# GitHub Copilot workspace storage
.github/copilot-workspace*

# Python virtual environment
.venv/

# Python cache files
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Screenshots and temporary image files in root
/Screenshot*
*.tar
*.tar.gz

# Compiled objects
*.o
*.elf
*.bin
*.hex

# IDE files
*.swp
*.swo
*~
