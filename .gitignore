# PlatformIO build output
.pio/

# OTA release signing — NEVER commit private keys or built release artifacts
keys/
release/
*.pem
*_ed25519*
!*_ed25519.pub.hex

# Cloud-OTA bench throwaways (scripts/ota-bench/) — keys, signed artifacts, images
scripts/ota-bench/keys/
scripts/ota-bench/bench-key.json
scripts/ota-bench/out/
scripts/ota-bench/image.bin
scripts/ota-bench/*.bin

